    "issues": "https://github.com/asyncfnmc/demoted/issues"
  },
  "license": "Source Available - Personal Use Only, All Rights Reserved",
  "icon": "assets/demoted/icon.png",
  "environment": "client",
  "mixins": [
    {
      "config": "demoted.client.mixins.json",
      "environment": "client"
    }
  ],
  "depends": {
    "fabricloader": ">=0.19.3",
    "minecraft": "26.1.2"
  }
}
